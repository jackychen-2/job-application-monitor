# ── IMAP Configuration ─────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FOLDER=INBOX

# ── Database ───────────────────────────────────────────
DATABASE_URL=sqlite:///job_monitor.db

# ── Scanning ───────────────────────────────────────────
MAX_SCAN_EMAILS=20
IMAP_TIMEOUT_SEC=30

# ── LLM Configuration ─────────────────────────────────
LLM_ENABLED=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...
LLM_TIMEOUT_SEC=45
COST_INPUT_PER_MTOK=0.15
COST_OUTPUT_PER_MTOK=0.60

# ── Server ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Auth / OAuth (Google-only) ─────────────────────────
AUTH_SESSION_TTL_DAYS=30
AUTH_COOKIE_NAME=job_monitor_session
AUTH_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.readonly
# Use `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
TOKEN_ENCRYPTION_KEY=
LEGACY_OWNER_EMAIL=

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=job_monitor.log
